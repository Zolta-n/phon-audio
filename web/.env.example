# Copy to .env.local for local development. On Vercel, set these in
# Project Settings → Environment Variables.
#
# NEXT_PUBLIC_* vars are exposed to the browser. The rest are server-only —
# NEVER prefix them with NEXT_PUBLIC_.

# Supabase project URL (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — safe for the browser, RLS enforced
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — SERVER-ONLY, bypasses RLS
SUPABASE_SERVICE_KEY=

# Canonical app URL, no trailing slash (e.g. https://phon-audio.vercel.app)
# Used for Supabase auth redirects.
NEXT_PUBLIC_APP_URL=

# Anthropic API key — SERVER-ONLY, used by the component scrape route
ANTHROPIC_API_KEY=

# Tavily Search API key — SERVER-ONLY. Backend for spec collection's web search.
# When set, the scraper uses the Tavily API (reliable on datacenter/serverless
# IPs); when unset it falls back to scraping DuckDuckGo, which is blocked on many
# cloud hosts. Free key (no card, ~1000 searches/mo): https://tavily.com/
TAVILY_API_KEY=
